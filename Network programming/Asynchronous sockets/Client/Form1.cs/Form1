using System.Net;
using System.Net.Sockets;
using System.Text;

namespace WinFormsApp5
{
    public partial class Form1 : Form
    {
        private Socket _socket;
        private IPEndPoint _serverEndpoint = new IPEndPoint(IPAddress.Loopback, 5001);

        public Form1()
        {
            InitializeComponent();

            btnDisconnect.Enabled = false;
            btnSend.Enabled = false;
            btnRefresh.Enabled = false;
        }

        private async void btnConnect_Click(object sender, EventArgs e)
        {
            try
            {
                _socket = new Socket(AddressFamily.InterNetwork, SocketType.Stream, ProtocolType.Tcp);
                await _socket.ConnectAsync(_serverEndpoint);

                byte[] username = Encoding.UTF8.GetBytes(txtUsername.Text);
                await _socket.SendAsync(username);

                btnConnect.Enabled = false;
                btnDisconnect.Enabled = true;
                btnSend.Enabled = true;
                btnRefresh.Enabled = true;

                MessageBox.Show("connected!");
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }

        private async void btnDisconnect_Click(object sender, EventArgs e)
        {
            if (_socket == null || !_socket.Connected)
                return;

            await _socket.DisconnectAsync(false);
            _socket.Close();

            btnConnect.Enabled = true;
            btnDisconnect.Enabled = false;
            btnSend.Enabled = false;
            btnRefresh.Enabled = false;
        }

        private async void btnSend_Click(object sender, EventArgs e)
        {
            if (_socket == null || !_socket.Connected)
                return;

            string msg = "MSG:" + txtMessage.Text;

            await _socket.SendAsync(Encoding.UTF8.GetBytes(msg));

            txtMessage.Clear();
        }

        private async void btnRefresh_Click(object sender, EventArgs e)
        {
            if (_socket == null || !_socket.Connected)
                return;

            await _socket.SendAsync(Encoding.UTF8.GetBytes("GET"));

            byte[] buffer = new byte[4096];
            int received = await _socket.ReceiveAsync(buffer);

            txtChat.Text = Encoding.UTF8.GetString(buffer, 0, received);
        }
    }
}
