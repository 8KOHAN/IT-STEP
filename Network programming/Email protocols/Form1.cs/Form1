using System.Net;
using System.Net.Mail;

namespace WinFormsApp10
{
    public partial class Form1 : Form
    {
        private string filePath = "";

        public Form1()
        {
            InitializeComponent();
        }

        private void btnAttach_Click(object sender, EventArgs e)
        {
            OpenFileDialog dialog = new OpenFileDialog();

            if (dialog.ShowDialog() == DialogResult.OK)
            {
                filePath = dialog.FileName;
                txtFile.Text = filePath;
            }
        }

        private void btnSend_Click(object sender, EventArgs e)
        {
            try
            {
                var fromAddress = new MailAddress(txtFrom.Text);
                var toAddress = new MailAddress(txtTo.Text);

                var password = txtPassword.Text.Replace(" ", "");
                var subject = txtSubject.Text;
                var msg = txtMessage.Text;

                using var smtp = new SmtpClient("smtp.gmail.com", 587);

                smtp.Credentials = new NetworkCredential(fromAddress.Address, password);
                smtp.EnableSsl = true;

                var message = new MailMessage(fromAddress, toAddress)
                {
                    Subject = subject,
                    Body = msg
                };

                if (!string.IsNullOrEmpty(filePath))
                {
                    message.Attachments.Add(new Attachment(filePath));
                }

                smtp.Send(message);

                MessageBox.Show("Message sent!");
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }
    }
}
