using System.Diagnostics;

namespace WinFormsApp2
{
    public partial class Form1 : Form
    {
        public Form1()
        {
            InitializeComponent();
            buttonStart.Click += buttonStart_Click;
        }

        private void buttonStart_Click(object sender, EventArgs e)
        {
            string path = textBoxPath.Text;
            string extension = textBoxExtension.Text;

            if (!Directory.Exists(path))
            {
                MessageBox.Show("Directory not found");
                return;
            }

            if (!extension.StartsWith("."))
                extension = "." + extension;

            string[] files = Directory.GetFiles(path, "*", SearchOption.AllDirectories);

            Stopwatch sw1 = Stopwatch.StartNew();

            int sequentialCount = 0;

            foreach (var file in files)
            {
                if (Path.GetExtension(file) == extension)
                    sequentialCount++;
            }

            sw1.Stop();

            Stopwatch sw2 = Stopwatch.StartNew();

            int parallelCount = files
                .AsParallel()
                .Count(f => Path.GetExtension(f) == extension);

            sw2.Stop();

            labelResult.Text = $"Files found: {parallelCount}";
            labelSequential.Text = $"Sequential time: {sw1.Elapsed}";
            labelParallel.Text = $"Parallel time: {sw2.Elapsed}";
        }
    }
}
