namespace WinFormsApp1
{
    public partial class Form1 : Form
    {
        CancellationTokenSource cts;

        public Form1()
        {
            InitializeComponent();

            buttonOpen.Click += buttonOpen_Click;
            buttonEncrypt.Click += buttonEncrypt_Click;
            buttonCancel.Click += buttonCancel_Click;
        }

        private void buttonOpen_Click(object sender, EventArgs e)
        {
            if (openFileDialog1.ShowDialog() == DialogResult.OK)
            {
                textPath.Text = openFileDialog1.FileName;
            }
        }

        private async void buttonEncrypt_Click(object sender, EventArgs e)
        {
            if (!File.Exists(textPath.Text))
            {
                MessageBox.Show("File not found.");
                return;
            }

            int key = (int)numericKey.Value;

            cts = new CancellationTokenSource();

            labelStatus.Text = "Encrypting...";

            try
            {
                await Task.Run(() => EncryptFile(textPath.Text, key, cts.Token));

                labelStatus.Text = "Encryption completed.";
            }
            catch
            {
                labelStatus.Text = "Encryption cancelled.";
            }
        }

        private void buttonCancel_Click(object sender, EventArgs e)
        {
            cts?.Cancel();
        }

        void EncryptFile(string path, int key, CancellationToken token)
        {
            string text = File.ReadAllText(path);

            char[] buffer = text.ToCharArray();

            for (int i = 0; i < buffer.Length; i++)
            {
                if (token.IsCancellationRequested)
                    throw new OperationCanceledException();

                buffer[i] = (char)(buffer[i] + key);
            }

            string encrypted = new string(buffer);

            string newFile = Path.Combine(
                Path.GetDirectoryName(path),
                "encrypted.txt");

            File.WriteAllText(newFile, encrypted);
        }
    }
}
