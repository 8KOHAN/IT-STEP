namespace WinFormsApp4
{
    public partial class Form1 : Form
    {
        private ScannerService scanner = new();
        private List<string> foundFiles = new();

        public Form1()
        {
            InitializeComponent();

            btnStart.Click += BtnStart_Click;
            btnPause.Click += (s, e) => scanner.Pause();
            btnResume.Click += (s, e) => scanner.Resume();
            btnStop.Click += (s, e) => scanner.Stop();
            btnLoadWords.Click += BtnLoadWords_Click;
        }

        private async void BtnStart_Click(object sender, EventArgs e)
        {
            listBox1.Items.Clear();
            foundFiles.Clear();

            var words = txtWords.Text
                .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
                .ToList();

            string outputDir = txtOutput.Text;

            if (!Directory.Exists(outputDir))
                Directory.CreateDirectory(outputDir);

            await scanner.Start(words, outputDir, UpdateProgress);

            var top = scanner.GetTopWords();

            foreach (var f in Directory.GetFiles(outputDir))
            {
                listBox1.Items.Add(f);
                foundFiles.Add(f);
            }

            string reportPath = Path.Combine(outputDir, "report.txt");
            ReportService.Generate(reportPath, foundFiles, top);

            listBox1.Items.Add("=== REPORT CREATED ===");
        }

        private void UpdateProgress(int value)
        {
            if (InvokeRequired)
            {
                Invoke(new Action<int>(UpdateProgress), value);
                return;
            }
            progressBar1.Value = value;
        }

        private void BtnLoadWords_Click(object sender, EventArgs e)
        {
            using OpenFileDialog ofd = new();
            if (ofd.ShowDialog() == DialogResult.OK)
            {
                txtWords.Text = File.ReadAllText(ofd.FileName);
            }
        }
    }
}
